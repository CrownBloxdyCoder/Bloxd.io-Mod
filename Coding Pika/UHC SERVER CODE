        customAttributes: {
          enchantments: { Protection: 3, "Health Regen": 2 },
          enchantmentTier: "Tier 5",
        },
      });
      api.setItemSlot(playerId, 48, "Diamond Gauntlets", 1, {
        customAttributes: {
          enchantments: { Protection: 3, "Health Regen": 2 },
          enchantmentTier: "Tier 5",
        },
      });
      api.setItemSlot(playerId, 49, "Diamond Leggings", 1, {
        customAttributes: {
          enchantments: { Protection: 3, "Health Regen": 2 },
          enchantmentTier: "Tier 5",
        },
      });
      api.setItemSlot(playerId, 50, "Diamond Boots", 1, {
        customAttributes: {
          enchantments: { Protection: 3, "Health Regen": 2 },
          enchantmentTier: "Tier 5",
