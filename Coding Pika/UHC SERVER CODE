};
//Place here your arena cords!
const arenaMin = [ -176, 0, 112 ];
const arenaMax = [ -45, 30, -15 ];
function isAllowed(block) {
  return (
    block === "Diamond Spikes" || block === "Net" || block.includes("Ladder")
  );
}
const placedBlocks = new Map();
function isInsideArena(x, y, z) {
  return api.isInsideRect([x,y,z],arenaMin, arenaMax);
}
onPlayerChangeBlock = (playerId, x, y, z, fromBlock, toBlock) => {
  if (!isInsideArena(x, y, z)) return;
  const allowedBlocks = ["Diamond Spikes", "Net"];
  if (fromBlock === "Air" && toBlock !== "Air") {
    if (!allowedBlocks.includes(toBlock)) {
      api.setBlock(x, y, z, "Air");
      api.sendMessage(playerId, "You can only place Nets or Diamond Spikes!");
      return;
    }
  }
  if (toBlock === "Air" && fromBlock !== "Air") {
    if (!allowedBlocks.includes(fromBlock)) {
      api.setBlock(x, y, z, fromBlock);
      api.sendMessage(playerId, "You can only break Nets or Diamond Spikes!");
      api.setCantChangeBlockType(playerId, fromBlock);
      return;
    }
  }
  const key = `${x},${y},${z}`;
  if (fromBlock === "Air" && toBlock !== "Air") {
    if (!isAllowed(toBlock)) {
      api.setBlock(x, y, z, "Air");
      return false;
    }
    placedBlocks.set(key, {
      owner: playerId,
      pos: [x, y, z],
      time: api.now(),
    });
  }
  if (toBlock === "Air" && fromBlock !== "Air") {
    if (!isAllowed(fromBlock)) {
      api.setBlock(x, y, z, fromBlock);
      api.setCantChangeBlockType(playerId, fromBlock);
      return false;
    }
    placedBlocks.delete(key);
  }
};
tick = () => {
  const now = api.now();
  for (const [key, data] of placedBlocks.entries()) {
    if (now - data.time > 30000) {
      const [x, y, z] = data.pos;
      api.setBlock(x, y, z, "Air");
      placedBlocks.delete(key);
    }
  }
};
onPlayerLeave = (playerId) => {
  for (const [key, data] of placedBlocks.entries()) {
    if (data.owner === playerId) {
      const [x, y, z] = data.pos;
      api.setBlock(x, y, z, "Air");
      placedBlocks.delete(key);
    }
  }
};
